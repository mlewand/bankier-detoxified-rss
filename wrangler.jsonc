/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "bankier-detoxified-rss",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-16",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"triggers": {
		"crons": [
			"*/2 * * * *"
		]
	},
	"kv_namespaces": [
		{
			"binding": "ARTICLE_CACHE",
			"id": "cb664a901f9d49719aff69e4f30c8072",
			"preview_id": "288ad65cddca4281ac7d678bc2e70e9c"
		}
	],
	"vars": {
		"UPSTREAM_RSS_URL": "https://www.bankier.pl/rss/wiadomosci.xml"
	}
	// LLM_API_KEY is a secret — set it with:
	//   wrangler secret put LLM_API_KEY
	// For local dev, add to .dev.vars:
	//   LLM_API_KEY=your_token_plan_key_here
}